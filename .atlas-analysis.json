  "keyFeatures": [
    "Ecommerce dashboard with metrics, charts, and order tracking",
    "ApexCharts integration for line and bar charts",
    "Collapsible sidebar with hover expand and mobile support",
    "Dark mode support via ThemeContext",
    "Authentication pages (Sign In, Sign Up) with Next.js Server Actions",
    "Comprehensive UI elements: alerts, avatars, badges, buttons, modals, dropdowns",
    "Form components: inputs, selects, date picker (Flatpickr), multi-select",
    "Basic tables component",
    "Calendar page using FullCalendar",
    "User profile page",
    "Interactive world map with jVectorMap",
    "Built with Next.js 16 App Router and React Server Components",
    "TypeScript throughout",
    "Tailwind CSS v4 with responsive design"
  ],
  "publicApiSurface": [
    "EcommerceMetrics component",
    "MonthlySalesChart component",
    "MonthlyTarget component",
    "StatisticsChart component",
    "RecentOrders component",
    "DemographicCard component",
    "CountryMap component",
    "AppSidebar layout component",
    "AppHeader layout component",
    "SidebarContext (useSidebar hook)",
    "ThemeContext (useTheme hook)",
    "useModal hook",
    "useGoBack hook",
    "Alert component",
    "Avatar component",
    "Badge component",
    "Button component",
    "Modal component",
    "Dropdown component",
    "Table component",
    "Form / Input / Select / MultiSelect / DatePicker form components",
    "SignInForm / SignUpForm auth components",
    "LineChart / BarChart chart components",
    "PageBreadCrumb component",
    "ThemeToggleButton component"
  ]
}

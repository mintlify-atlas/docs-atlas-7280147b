{
  "projectType": "frontend",
  "projectName": "TailAdmin Next.js",
  "projectDescription": "A free, open-source admin dashboard template built with Next.js 16, React 19, TypeScript, and Tailwind CSS v4, providing ready-to-use UI components and pages for building admin panels and dashboards.",
  "theme": "willow",
  "primaryColor": "#141c2b",
  "lightColor": "#4257e2",
  "darkColor": "#9cacec",

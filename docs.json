{
  "$schema": "https://mintlify.com/docs.json",
  "name": "TailAdmin Next.js",
  "theme": "willow",
  "colors": {
    "primary": "#141c2b",
    "light": "#4257e2",
    "dark": "#9cacec"
  },
  "favicon": "https://media.brand.dev/f82529c6-b186-4f04-a487-6294dc8a5b24.png",
  "logo": {
    "light": "https://media.brand.dev/b7bf0b41-34b4-40e9-a402-5c01401df9d0.svg",
    "dark": "https://media.brand.dev/b7bf0b41-34b4-40e9-a402-5c01401df9d0.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/TailAdmin/free-nextjs-admin-dashboard"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/TailAdmin/free-nextjs-admin-dashboard"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Introduction",
            "pages": ["introduction", "quickstart", "project-structure"]
          },
          {
            "group": "Configuration",
            "pages": ["configuration/theming", "configuration/dark-mode", "configuration/sidebar"]
          }
        ]
      },
      {
        "tab": "Components",
        "groups": [
          {
            "group": "Dashboard",
            "pages": ["components/dashboard/ecommerce"]
          },
          {
            "group": "UI Elements",
            "pages": [
              "components/ui/alerts",
              "components/ui/avatar",
              "components/ui/badge",
              "components/ui/buttons",
              "components/ui/images",
              "components/ui/videos",
              "components/ui/modal",
              "components/ui/dropdown"
            ]
          },
          {
            "group": "Charts",
            "pages": [
              "components/charts/line-chart",
              "components/charts/bar-chart"
            ]
          },
          {
            "group": "Forms",
            "pages": [
              "components/forms/form-elements",
              "components/forms/input",
              "components/forms/select",
              "components/forms/date-picker",
              "components/forms/multi-select"
            ]
          },
          {
            "group": "Tables",
            "pages": ["components/tables/basic-tables"]
          }
        ]
      },
      {
        "tab": "Pages",
        "groups": [
          {
            "group": "Auth Pages",
            "pages": ["pages/auth/sign-in", "pages/auth/sign-up"]
          },
          {
            "group": "Other Pages",
            "pages": [
              "pages/calendar",
              "pages/user-profile",
              "pages/blank-page",
              "pages/404-error"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Customization",
            "pages": ["guides/customization", "guides/adding-pages", "guides/adding-components"]
          },
          {
            "group": "Deployment",
            "pages": ["guides/deployment/vercel", "guides/deployment/other"]
          },
          {
            "group": "Upgrade",
            "pages": ["guides/changelog", "guides/upgrade-guide"]
          }
        ]
      }
    ]
  }
}
